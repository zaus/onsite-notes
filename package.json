{
  "name": "onsite-notes",
  "version": "1.0.0",
  "description": "Simple note-taking application with time tracking",
  "main": "dist/main/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && webpack --config webpack.config.js && cp src/renderer/index.html src/renderer/style.css dist/renderer/",
    "start": "npm run build && electron .",
    "dev": "electron ."
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "electron": "^29.1.0"
  },
  "devDependencies": {
    "@codemirror/autocomplete": "^6.12.0",
    "@codemirror/commands": "^6.3.3",
    "@codemirror/language": "^6.10.1",
    "@codemirror/search": "^6.5.6",
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.26.3",
    "@electron/rebuild": "^3.6.0",
    "@lezer/highlight": "^1.2.0",
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.11.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.90.3",
    "webpack-cli": "^5.1.4"
  }
}
