{
  "name": "onsite-notes",
  "version": "1.0.0",
  "description": "Simple note-taking application with time tracking",
  "main": "dist/main/main.js",
  "scripts": {
    "build": "npx tsc -p tsconfig.json && webpack --config webpack.config.js",
    "test": "node --import tsx --test tests/*.test.ts",
    "start": "npm run build && electron .",
    "dev": "electron .",
    "//safemode": "added safe mode scripts to help with GPU-related crashes on some machines",
    "start:safe": "npm run build && set ELECTRON_SAFE_MODE=1&& electron .",
    "dev:safe": "set ELECTRON_SAFE_MODE=1&& electron ."
  },
  "dependencies": {
    "@types/sql.js": "^1.4.9",
    "electron": "^29.1.0",
    "sql.js": "^1.14.0"
  },
  "devDependencies": {
    "@codemirror/autocomplete": "^6.12.0",
    "@codemirror/commands": "^6.3.3",
    "@codemirror/language": "^6.10.1",
    "@codemirror/search": "^6.5.6",
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.26.3",
    "@electron/rebuild": "^3.6.0",
    "@lezer/highlight": "^1.2.0",
    "@types/node": "^20.19.33",
    "copy-webpack-plugin": "^13.0.1",
    "ts-loader": "^9.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "webpack": "^5.90.3",
    "webpack-cli": "^5.1.4"
  }
}
